# ==============================================================================
# ia-agent-fwk Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values for your environment.
# All variables use the IAFWK_ prefix with __ (double underscore) as the
# nesting separator. See config/default.yaml for the full configuration schema.
#
# WARNING: Default values below are for DEVELOPMENT ONLY. Never use these
# in staging or production.
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
# Environment profile: development | testing | staging | production
IAFWK_APP__ENVIRONMENT=development
# IAFWK_APP__DEBUG=false
# IAFWK_APP__LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------
IAFWK_SERVER__HOST=0.0.0.0
IAFWK_SERVER__PORT=8000
IAFWK_SERVER__WORKERS=1
IAFWK_SERVER__RELOAD=true

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------
IAFWK_AUTH__ENABLED=true
# IAFWK_AUTH__JWT__SECRET_KEY=change-me-in-production
# IAFWK_AUTH__JWT__ALGORITHM=HS256

# ------------------------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# ------------------------------------------------------------------------------
IAFWK_DATABASE__URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ia_agent_fwk
IAFWK_DATABASE__POOL_SIZE=10
IAFWK_DATABASE__MAX_OVERFLOW=20
IAFWK_DATABASE__ECHO=false

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
IAFWK_REDIS__URL=redis://localhost:6379/0
IAFWK_REDIS__MAX_CONNECTIONS=20

# ------------------------------------------------------------------------------
# LLM Providers
# ------------------------------------------------------------------------------
IAFWK_LLM__DEFAULT_PROVIDER=openai

# OpenAI  (obtain from https://platform.openai.com/api-keys)
OPENAI_API_KEY=
IAFWK_LLM__PROVIDERS__OPENAI__API_KEY=
IAFWK_LLM__PROVIDERS__OPENAI__DEFAULT_MODEL=gpt-4o
IAFWK_LLM__PROVIDERS__OPENAI__TEMPERATURE=0.7
IAFWK_LLM__PROVIDERS__OPENAI__MAX_TOKENS=4096
IAFWK_LLM__PROVIDERS__OPENAI__TIMEOUT=60

# Anthropic  (obtain from https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=
IAFWK_LLM__PROVIDERS__ANTHROPIC__API_KEY=
IAFWK_LLM__PROVIDERS__ANTHROPIC__DEFAULT_MODEL=claude-sonnet-4-20250514
IAFWK_LLM__PROVIDERS__ANTHROPIC__TEMPERATURE=0.7
IAFWK_LLM__PROVIDERS__ANTHROPIC__MAX_TOKENS=4096
IAFWK_LLM__PROVIDERS__ANTHROPIC__TIMEOUT=60

# Ollama (local)
IAFWK_LLM__PROVIDERS__OLLAMA__BASE_URL=http://localhost:11434
IAFWK_LLM__PROVIDERS__OLLAMA__DEFAULT_MODEL=llama3.1

# ------------------------------------------------------------------------------
# Memory
# ------------------------------------------------------------------------------
IAFWK_MEMORY__DEFAULT_BACKEND=in_memory

# ------------------------------------------------------------------------------
# RAG
# ------------------------------------------------------------------------------
IAFWK_RAG__DEFAULT_EMBEDDING_PROVIDER=openai
IAFWK_RAG__STORAGE_BACKEND=pgvector

# ------------------------------------------------------------------------------
# Execution
# ------------------------------------------------------------------------------
IAFWK_EXECUTION__MODE=sync
# IAFWK_EXECUTION__WORKER_SHUTDOWN_TIMEOUT=300
# IAFWK_EXECUTION__CELERY__BROKER_URL=redis://localhost:6379/0
# IAFWK_EXECUTION__CELERY__RESULT_BACKEND=redis://localhost:6379/0
# IAFWK_EXECUTION__CELERY__TASK_TIMEOUT=300
# IAFWK_EXECUTION__CELERY__WORKER_CONCURRENCY=4
# IAFWK_EXECUTION__CELERY__RESULT_EXPIRES=86400

# ------------------------------------------------------------------------------
# Integrations
# ------------------------------------------------------------------------------
# IAFWK_INTEGRATIONS__SLACK__ENABLED=false
# IAFWK_INTEGRATIONS__SLACK__BOT_TOKEN=
# IAFWK_INTEGRATIONS__SLACK__SIGNING_SECRET=

# IAFWK_INTEGRATIONS__EMAIL__ENABLED=false
# IAFWK_INTEGRATIONS__EMAIL__SMTP__HOST=smtp.gmail.com
# IAFWK_INTEGRATIONS__EMAIL__SMTP__USERNAME=
# IAFWK_INTEGRATIONS__EMAIL__SMTP__PASSWORD=

# IAFWK_INTEGRATIONS__WHATSAPP__ENABLED=false
# IAFWK_INTEGRATIONS__WHATSAPP__ACCESS_TOKEN=

# ------------------------------------------------------------------------------
# Observability
# ------------------------------------------------------------------------------
IAFWK_OBSERVABILITY__LOGGING__FORMAT=json
IAFWK_OBSERVABILITY__LOGGING__LEVEL=INFO
# IAFWK_OBSERVABILITY__TRACING__ENABLED=false
# IAFWK_OBSERVABILITY__TRACING__ENDPOINT=http://localhost:4317
# IAFWK_OBSERVABILITY__METRICS__ENABLED=false

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
IAFWK_SECURITY__RATE_LIMITING__ENABLED=true
IAFWK_SECURITY__RATE_LIMITING__DEFAULT_RATE=60/minute
