# ─────────────────────────────────────────────────────────────
# Ansible deployment — environment variables
# Copy to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# EC2 instance IP (from Terraform output or AWS console)
EC2_HOST=

# Path to SSH private key (must match Terraform key_pair_name)
SSH_KEY_FILE=~/.ssh/your-key.pem

# GitHub repo to clone on EC2 (default: public repo)
# GITHUB_REPO=https://github.com/hperezrodal/ia-agent-fwk.git
# GITHUB_BRANCH=main

# Ollama models
# OLLAMA_MODEL=qwen3:30b-a3b-q4_K_M
# OLLAMA_EMBED_MODEL=nomic-embed-text

# Application
# IAFWK_API_KEYS=your-api-key-here

# Grafana
# GRAFANA_PASSWORD=admin
